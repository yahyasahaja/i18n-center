PORT=8080
ENV=development
DB_HOST=localhost
DB_PORT=5432
DB_USER=i18n_user
DB_PASSWORD=i18n_password
DB_NAME=i18n_center
DB_SSLMODE=disable
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
JWT_SECRET=your-secret-key-change-in-production-min-32-characters-long
JWT_EXPIRY=24h
OPENAI_API_KEY=
CORS_ORIGIN=http://localhost:3000

# Datadog Observability
# Set DD_ENABLED=true in production; leave false for local development.
# Logs are always structured (JSON in production) and streamed by the DD agent — no change needed here.
DD_ENABLED=false
DD_AGENT_HOST=localhost
DD_DOGSTATSD_PORT=8125

# Per-metric toggles (only relevant when DD_ENABLED=true).
# Set to false/0 to disable an individual metric without turning off DD entirely.
DD_METRIC_LATENCY_ENABLED=true
